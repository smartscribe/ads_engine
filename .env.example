# Copy to .env and fill in real values. NEVER commit .env to git.

# Anthropic (for intake parsing + copy generation)
ANTHROPIC_API_KEY=sk-ant-...

# Meta Marketing API
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_

# Google Ads API
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_CHANNEL=#ads-engine

# Image Generation (intern: fill in after choosing provider)
IMAGE_GEN_API_KEY=
IMAGE_GEN_PROVIDER=

# Video Generation (intern: fill in if using)
VIDEO_GEN_API_KEY=
VIDEO_GEN_PROVIDER=

# Decision Engine Thresholds
MIN_SPEND_FOR_DECISION=50
MIN_DAYS_LIVE=3
KILL_CPA_MULTIPLIER=2.0
SCALE_CPA_MULTIPLIER=0.7
DAILY_BUDGET_LIMIT=700
